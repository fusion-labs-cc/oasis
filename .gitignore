# Python
*.pyc
__pycache__/
/oasis/

# Bundled Windows runtime (local portal bundle: python interpreter + ffmpeg,
# never committed -- so `git pull` auto-updates only source, never the runtime)
/python/
/bin/
/oasis-portal-win64.zip

# Media & temp
*.mp4
*.jpg
*.m3u8
*.DS_Store

# Chrome
chromedriver*

# Aider
.aider*

# PyInstaller (local builds; CI produces the shipped zips)
/build/
/dist/
/oasis-backend-*.zip
/oasis-backend-patch.zip
# Build-time stamps: the git tag, the release asset for this OS, and the
# fingerprint of the frozen runtime (see release.yml, scripts/app_payload.py).
/VERSION
/PLATFORM
/RUNTIME
# Staging dir for the source-only payload, built by scripts/app_payload.py.
/app/

# Node
node_modules/
.next/

# Misc
queue.txt

# SQLite
*.db

# The access code's scrypt hash + the session tokens of paired devices. Local
# state, never shipped: a committed one would hand every install the same code.
oasis.auth.json
