# Default backend URL baked into the client bundle. The browser calls this
# local FastAPI backend directly. Users can override it at runtime from the
# header connection settings (stored in their browser), so this only sets the
# default. Must be NEXT_PUBLIC_ to be readable in the browser.
#
# Leave unset to use the built-in default (http://localhost:8000).
# Recommend http://localhost / http://127.0.0.1: HTTPS pages can call those
# without mixed-content errors, but NOT a LAN IP like http://192.168.x.x.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Download link for the OASIS portal bundle (oasis-portal-win64.zip), shown on
# the entrance gate so a new visitor without the portal can grab it. Upload the
# zip somewhere shareable (e.g. Google Drive, "anyone with the link") and paste
# the URL here. Must be NEXT_PUBLIC_ to be readable in the browser.
# Leave unset to hide the download prompt entirely.
# NEXT_PUBLIC_PORTAL_DOWNLOAD_URL=https://drive.google.com/file/d/XXXXXXXX/view

# --- Backend (api.py), for reference ---
# The backend restricts CORS to the frontend origin(s). When self-hosting the
# public site, set this (comma-separated) to your deployed domain:
# ALLOWED_ORIGINS=https://your-site.example.com,http://localhost:3000
