{
  "manifest_version": 3,
  "name": "OASIS",
  "version": "1.1.0",
  "description": "儲存目前分頁的網址與儲存時間，並可在一般視窗與無痕視窗之間共用清單。",
  "permissions": ["storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "OASIS",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "incognito": "spanning"
}
