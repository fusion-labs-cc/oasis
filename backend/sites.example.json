{
  "id": "example",
  "name": "Example Site",
  "display_domain": "example.com",
  "_comment": "Adapter schema. Copy this into backend/sites/<yoursite>.json and fill in selectors for the site you want to read. Adapters in backend/sites/ are tracked in git, ship with releases, and update via git pull; you can add your own alongside them.",
  "domains": [
    "example.com"
  ],
  "domain_prefixes": [],
  "user_agent": "",
  "title_selectors": [
    "h1",
    "title"
  ],
  "title_suffix_strip": [
    " - Example Site"
  ],
  "tag_selectors": [
    "a.tag"
  ],
  "actress_selectors": [
    "a[href*='/cast/']"
  ],
  "cover": {
    "selectors": [
      {"css": "meta[property='og:image']", "attr": "content"},
      {"css": ".player-poster", "attr": "style"}
    ]
  },
  "headers": {
    "Referer": "{page_url}"
  },
  "driver": {
    "performance_log": false,
    "stealth": false
  },
  "wait": {
    "seconds": 2,
    "css": "h1",
    "timeout": 15
  },
  "m3u8": {
    "regexes": [
      "https?://[^\\s\"']+\\.m3u8[^\\s\"']*"
    ],
    "use_performance_log": false,
    "scan_iframes": false,
    "frame_scripts": [],
    "retry": {
      "wait_seconds": 5,
      "attempts": 1,
      "click_selectors": [
        ".play-button",
        "xpath://a[normalize-space()='Server 2']"
      ],
      "click_wait_seconds": 3
    }
  },
  "download": {
    "strip_fake_header": false
  }
}
