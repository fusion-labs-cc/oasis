{
  "id": "missav",
  "name": "MissAV",
  "display_domain": "missav.ws",
  "domain_prefixes": [
    "missav"
  ],
  "title_selectors": [
    "h1"
  ],
  "title_suffix_strip": [
    " - MissAV"
  ],
  "tag_selectors": [
    "div.text-secondary a"
  ],
  "headers": {
    "Referer": "{page_url}",
    "Origin": "https://missav.ws"
  },
  "driver": {
    "performance_log": true,
    "stealth": true
  },
  "wait": {
    "seconds": 5,
    "css": "h1",
    "timeout": 15
  },
  "m3u8": {
    "regexes": [
      "https?://[^\\s\"']+\\.m3u8[^\\s\"']*",
      "(?:source|src|file|url|hlsUrl|videoUrl)\\s*[:=]\\s*['\"]?(https?://[^\\s'\"]+\\.m3u8[^\\s'\"]*)"
    ],
    "use_performance_log": true,
    "retry": {
      "wait_seconds": 5,
      "click_selectors": [
        ".plyr__control--overlaid, .vjs-big-play-button, [class*=\"play\"]"
      ],
      "click_wait_seconds": 3
    }
  }
}
